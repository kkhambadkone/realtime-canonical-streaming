{
  "$schema": "https://github.com/Azure/data-api-builder/releases/download/v1.7.93/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "Server=localhost,1433;Database=mydb;User Id=sa;Password=RootPassword@1234;TrustServerCertificate=True;",
    "options": {
      "set-session-context": false
    }
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api",
      "request-body-strict": true
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql",
      "allow-introspection": true
    },
    "mcp": {
      "enabled": true,
      "path": "/mcp"
    },
    "host": {
      "cors": {
        "origins": [],
        "allow-credentials": false
      },
      "authentication": {
        "provider": "AppService"
      },
      "mode": "development"
    }
  },
  "entities": {
    "customers": {
      "source": {
        "object": "dbo.customers",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "customers",
          "plural": "customers"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "*"
            }
          ]
        }
      ]
    },
    "orders": {
      "source": {
        "object": "dbo.orders",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "orders",
          "plural": "orders"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "*"
            }
          ]
        }
      ]
    },
    "products": {
      "source": {
        "object": "dbo.products",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "products",
          "plural": "products"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "*"
            }
          ]
        }
      ]
    },
    "order_items": {
      "source": {
        "object": "dbo.order_items",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "order_items",
          "plural": "order_items"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "*"
            }
          ]
        }
      ]
    }
  }
}