# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434

# ── Kafka (reuse DataHub's broker) ────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=canonical
KAFKA_CONSUMER_GROUP=canonical-pipeline
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_NUM_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_APP_NAME=realtime-canonical-pipeline
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
SPARK_SHUFFLE_PARTITIONS=4

# ── Iceberg ───────────────────────────────────────────────────────────────────
ICEBERG_WAREHOUSE=file:///tmp/streaming_iceberg_warehouse
ICEBERG_RAW_NAMESPACE=raw_stream
ICEBERG_CANONICAL_NAMESPACE=canonical_stream
ICEBERG_CHECKPOINT_DIR=/tmp/streaming_checkpoints

# ── Streaming ─────────────────────────────────────────────────────────────────
MICRO_BATCH_INTERVAL_SECONDS=60
STREAMING_TRIGGER_INTERVAL=30 seconds
MAX_OFFSETS_PER_TRIGGER=10000

# ── MCP servers ───────────────────────────────────────────────────────────────
POSTGRES_MCP_URL=http://localhost:8765/sse
DATAHUB_MCP_URL=http://localhost:5012/sse
TERADATA_MCP_URL=http://localhost:8767/mcp/

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_CONNECTION_STRING=postgresql://postgres@localhost:5432/customers_db
POSTGRES_SCHEMA=public

# ── SQL Server (DAB REST) ─────────────────────────────────────────────────────
#DAB_BASE_URL=http://localhost:5000
#DAB_ENTITIES=["customers","products","orders","order_items"]

# ── Teradata ──────────────────────────────────────────────────────────────────
TETERADATA_HOST=<host>.env.trial.teradata.com
TERADATA_USER=demo_user
TERADATA_PASSWORD=
TERADATA_DATABASE=demo_userRADATA_ENABLED=true

# ── Snowflake ─────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=<HOST>
SNOWFLAKE_USER=KKHAMBADKONE
SNOWFLAKE_PASSWORD=
SNOWFLAKE_AUTHENTICATOR=snowflake
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=CANONICAL_DB
SNOWFLAKE_SCHEMA=CANONICAL_STREAM
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ── DataHub ───────────────────────────────────────────────────────────────────
DATAHUB_GMS_URL=http://localhost:8095
DATAHUB_ENV=DEV

# ── CDC polling ───────────────────────────────────────────────────────────────
CDC_POLL_INTERVAL_SECONDS=10
CDC_BATCH_SIZE=100

# ── Entities to stream ────────────────────────────────────────────────────────
ENTITIES=["customer","order","product"]
